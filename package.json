{
  "name": "WorkoutApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start --reset-cache --client-logs",
    "test": "jest",
    "lint": "eslint .",
    "types": "tsc --skipLibCheck",
    "depcheck": "depcheck",
    "emulator": "$ANDROID_HOME/emulator/emulator -avd Pixel_3a_API_34_extension_level_7_x86_64",
    "apk": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "release": "cd ./android && ./gradlew app:assembleRelease"
  },
  "dependencies": {
    "@op-engineering/op-sqlite": "^15.2.11",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-native-community/checkbox": "^0.5.20",
    "@react-native-vector-icons/material-design-icons": "^13.1.1",
    "@react-navigation/material-top-tabs": "^7.4.24",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.11",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "2.31.1",
    "react-native-gradle-plugin": "^0.71.19",
    "react-native-pager-view": "^8.0.1",
    "react-native-popup-menu": "^0.19.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-tab-view": "^4.3.0",
    "react-native-uuid": "^2.0.4",
    "react-native-worklets": "^0.8.1",
    "react-navigation-header-buttons": "^13.0.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^10.0.1",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.6",
    "@react-native/eslint-config": "0.81.6",
    "@react-native/metro-config": "0.81.6",
    "@react-native/typescript-config": "0.81.6",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.4",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.14.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20"
  }
}
